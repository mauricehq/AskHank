# Convex deployment identifier (set by `npx convex dev`)
CONVEX_DEPLOYMENT=

# Convex public URL for the React client (set by `npx convex dev`)
NEXT_PUBLIC_CONVEX_URL=

# Clerk authentication (optional — keyless mode works without these)
# Get from dashboard.clerk.com after claiming your application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
